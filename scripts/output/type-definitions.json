{
  "wallet": {
    "%d": "Wallet",
    "privacy_role": {
      "everyone": {
        "%d": "everyone",
        "permissions": {
          "view_all": false,
          "view_attachments": false,
          "search_for": false,
          "auto_binding": false
        }
      },
      "visible_to_creator_": {
        "%d": "Visible to creator",
        "permissions": {
          "view_all": true,
          "view_attachments": true,
          "search_for": true,
          "auto_binding": false
        },
        "%c": {
          "%x": "InjectedValue",
          "%n": {
            "%x": "Message",
            "%nm": "Created By",
            "%n": {
              "%x": "Message",
              "%nm": "equals",
              "%a": {
                "%x": "CurrentUser"
              }
            }
          }
        }
      }
    }
  },
